<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<main class="container">
    <div class="page-header">
        <h1>Edit Doctor</h1>
        <a href="/doctors" class="btn">Back</a>
    </div>

    <div class="form-container">
        <form action="/doctors/edit/<%= doctor.id %>" method="POST">
            <div class="form-group">
                <label for="name">Full Name *</label>
                <input type="text" id="name" name="name" value="<%= doctor.name %>" required>
            </div>

            <div class="form-group">
                <label for="specialty">Specialty *</label>
                <input type="text" id="specialty" name="specialty" value="<%= doctor.specialty %>" required>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="phone">Phone *</label>
                    <input type="tel" id="phone" name="phone" value="<%= doctor.phone %>" required>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" value="<%= doctor.email || '' %>">
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Update Doctor</button>
                <a href="/doctors" class="btn">Cancel</a>
            </div>
        </form>
    </div>
</main>

<%- include('../../partials/footer') %>