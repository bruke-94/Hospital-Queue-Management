<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<main class="container">
    <div class="page-header">
        <h1>Edit Patient</h1>
        <a href="/patients" class="btn">Back</a>
    </div>

    <div class="form-container">
        <form action="/patients/edit/<%= patient.id %>" method="POST">
            <div class="form-row">
                <div class="form-group">
                    <label for="firstName">First Name *</label>
                    <input type="text" id="firstName" name="firstName" value="<%= patient.first_name %>" required>
                </div>

                <div class="form-group">
                    <label for="lastName">Last Name *</label>
                    <input type="text" id="lastName" name="lastName" value="<%= patient.last_name %>" required>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="phone">Phone *</label>
                    <input type="tel" id="phone" name="phone" value="<%= patient.phone %>" required>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" value="<%= patient.email || '' %>">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="birthDate">Birth Date</label>
                    <input type="date" id="birthDate" name="birthDate" value="<%= patient.birth_date || '' %>">
                </div>
            </div>

            <div class="form-group">
                <label for="address">Address</label>
                <textarea id="address" name="address" rows="2"><%= patient.address || '' %></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Update Patient</button>
                <a href="/patients" class="btn">Cancel</a>
            </div>
        </form>
    </div>
</main>

<%- include('../../partials/footer') %>